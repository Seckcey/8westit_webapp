<?xml version="1.0" encoding="UTF-8"?>
<!--
  Milepost Agent — WiX v5 installer.

  Builds an MSI that:
    * installs EightWestAgent.exe to "Program Files\8 West IT\Agent"
    * writes PortalUrl + EnrollKey to HKLM\SOFTWARE\8WestIT\Agent
    * registers + starts the "EightWestAgent" Windows service (LocalSystem, auto-start)

  Build (handled by build-agent.ps1):
    wix build Product.wxs -ext WixToolset.Util.wixext -b "<bin dir>" -o EightWestAgent.msi

  Install on a client (key + portal supplied here or baked in by build-agent.ps1):
    msiexec /i EightWestAgent.msi ENROLLKEY=<64-hex-key> PORTAL=https://support.8westit.com /qn
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- Default value baked into the ENROLLKEY property.
       Direct build (build-agent.ps1): a 64-char placeholder; the real key is
       supplied at install via msiexec ENROLLKEY=... (WiX 5 forbids an empty Value).
       Template build (build-templates.ps1): passes its own matching placeholder
       that the portal byte-patches with the real key on per-client download. -->
  <?ifndef EnrollDefault ?>
    <?define EnrollDefault = "8WESTIT-ENROLLKEY-PLACEHOLDER-0000000000000000000000000000000000" ?>
  <?endif?>

  <Package Name="Milepost Agent"
           Manufacturer="8 West IT, LLC"
           Version="1.1.1.0"
           UpgradeCode="7B3F2A14-9C6E-4D2B-AE51-8F0C2D6A1E90"
           Compressed="yes"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of the Milepost Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Supplied on the msiexec command line (or baked in by the build script). -->
    <Property Id="ENROLLKEY" Secure="yes" Value="$(EnrollDefault)" />
    <Property Id="PORTAL" Secure="yes" Value="https://support.8westit.com" />

    <Feature Id="MainFeature" Title="Agent">
      <ComponentGroupRef Id="AgentComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="CompanyDir" Name="8 West IT">
        <Directory Id="INSTALLFOLDER" Name="Agent" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AgentComponents" Directory="INSTALLFOLDER">

      <!-- Service executable (resolved from the bind path passed via -b). -->
      <Component Id="cmpAgentExe" Bitness="always64">
        <File Id="EightWestAgentExe" Source="EightWestAgent.exe" KeyPath="yes" />

        <ServiceInstall Id="svcInstall"
                        Name="EightWestAgent"
                        DisplayName="Milepost Agent"
                        Description="Milepost RMM agent by 8 West IT — reports status and enables remote support."
                        Type="ownProcess"
                        Start="auto"
                        Account="LocalSystem"
                        ErrorControl="normal"
                        Vital="yes">
          <!-- Auto-restart the service on failure. -->
          <util:ServiceConfig FirstFailureActionType="restart"
                              SecondFailureActionType="restart"
                              ThirdFailureActionType="restart"
                              RestartServiceDelayInSeconds="60" />
        </ServiceInstall>
        <ServiceControl Id="svcControl"
                        Name="EightWestAgent"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>

      <!-- Config the service reads at startup. -->
      <Component Id="cmpRegConfig" Bitness="always64">
        <RegistryKey Root="HKLM" Key="SOFTWARE\8WestIT\Agent">
          <RegistryValue Type="string" Name="PortalUrl" Value="[PORTAL]" KeyPath="yes" />
          <RegistryValue Type="string" Name="EnrollKey" Value="[ENROLLKEY]" />
        </RegistryKey>
      </Component>

      <!-- Bundled RustDesk client (only when built with -d BundleRustDesk=1).
           The agent runs it silently on first start, so the install is
           self-contained. The "lite" template omits it (agent downloads on
           first run) for a ~1 MB installer. -->
      <?ifdef BundleRustDesk ?>
      <Component Id="cmpRustDeskSetup" Bitness="always64">
        <File Id="RustDeskSetup" Source="rustdesk-setup.exe" KeyPath="yes" />
      </Component>
      <?endif?>

    </ComponentGroup>
  </Package>
</Wix>
