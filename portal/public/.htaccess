# 8 West IT RMM portal — web root
#
# Kept intentionally minimal: some shared hosts (e.g. HostGator) return a 500
# if .htaccess uses directives their AllowOverride doesn't permit (Options,
# Header, etc.). The only directive the app actually needs is the Authorization
# passthrough below, so the agent's "Bearer <token>" header reaches PHP.
#
# If your host allows more, you may re-add hardening such as:
#   Options -Indexes
#   Header always set X-Content-Type-Options "nosniff"
# Test after adding each — if you get a 500, that directive isn't permitted.

# Serve index.php at the directory root. Some HostGator accounts' DEFAULT DirectoryIndex omits
# index.php, so the bare domain (support.8westit.com/) finds no index file and returns 403 while
# /index.php works. DirectoryIndex is a mod_dir directive HostGator permits (unlike Options/Header).
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP:Authorization} .
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
